<section class="hero-banner" data-section-id="{{ section.id }}"
  {% if section.settings.image %}
    style="background-image: url('{{ section.settings.image | image_url: width: 1920 }}');"
  {% else %}
    style="background-image: url('{{ 'hero-bg.png' | asset_url }}');"
  {% endif %}
>
  <div class="hero-inner">
    <div class="hero-cta-circle">
      <a href="{{ section.settings.button_url | default: '/collections' }}">
        <span class="hero-circle-text">{{ section.settings.heading | default: 'Shop Branded Items' }}</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Circle CTA text",
      "default": "Shop Branded Items"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Circle link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
