<section class="hero-banner" data-section-id="{{ section.id }}">
  <div class="hero-image-wrapper">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'eager', class: 'hero-bg-image' }}
    {% endif %}
  </div>

  <div class="hero-cta-circle">
    <a href="{{ section.settings.button_url | default: '/collections/all' }}">
      {% if section.settings.heading != blank %}
        <span class="hero-circle-text">{{ section.settings.heading }}</span>
      {% endif %}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Circle CTA text",
      "default": "Shop Branded Items"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Circle link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
