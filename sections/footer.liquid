<footer class="site-footer footer-navy" data-section-id="{{ section.id }}">
    <div class="footer-logo-area">
      {% if section.settings.footer_logo %}
        {{ section.settings.footer_logo | image_url: width: 400 | image_tag: class: 'footer-center-logo' }}
      {% else %}
        <img src="{{ 'gsd-footer-logo.png' | asset_url }}" alt="Golden State Dermatology" class="footer-center-logo">
      {% endif %}
    </div>

    <hr class="footer-divider">

    <nav class="footer-nav">
      {% if section.settings.menu.links.size > 0 %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="footer-nav-link">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/account" class="footer-nav-link">My account</a>
        <a href="/collections" class="footer-nav-link">Shop by Brand</a>
        <a href="/cart" class="footer-nav-link">Cart</a>
        <a href="/checkout" class="footer-nav-link">Checkout</a>
      {% endif %}
    </nav>

    <div class="footer-bottom">
      <div class="footer-bottom-logo">
        {% if section.settings.shop_logo %}
          {{ section.settings.shop_logo | image_url: width: 200 | image_tag }}
        {% else %}
          <img src="{{ 'gsd-shop-logo-white.png' | asset_url }}" alt="GSD Shop" class="footer-shop-logo-img">
        {% endif %}
      </div>

      <p class="footer-contact">
        {{ section.settings.contact_text | default: "Please contact the marketing team for any questions or concerns." }}
      </p>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer center logo"
    },
    {
      "type": "image_picker",
      "id": "shop_logo",
      "label": "Bottom-left shop logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact text",
      "default": "Please contact the marketing team for any questions or concerns."
    }
  ]
}
{% endschema %}
