<section class="brand-logos" data-section-id="{{ section.id }}">
  <div class="brand-logos-wrapper">
    {% for block in section.blocks %}
      <div class="brand-logo-item" {{ block.shopify_attributes }}>
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}">
        {% endif %}

        {% if block.settings.logo %}
          <div class="brand-logo-image">
            {{ block.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy' }}
          </div>
        {% elsif block.settings.default_image != blank %}
          <div class="brand-logo-image">
            <img src="{{ block.settings.default_image | asset_url }}" alt="{{ block.settings.name }}" loading="lazy">
          </div>
        {% endif %}

        {% if block.settings.name != blank %}
          <p class="brand-logo-name">{{ block.settings.name }}</p>
        {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Brand Logos",
  "settings": [],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "default_image",
          "label": "Default image filename (from assets)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "GOLDEN STATE DERMATOLOGY"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "default_image": "gsd-brand-dermatology.png",
            "name": "GOLDEN STATE DERMATOLOGY"
          }
        },
        {
          "type": "brand",
          "settings": {
            "default_image": "gsd-brand-dermatopathology.png",
            "name": "GOLDEN STATE DERMATOPATHOLOGY"
          }
        },
        {
          "type": "brand",
          "settings": {
            "default_image": "gsd-brand-plasticsurgery.png",
            "name": "GOLDEN STATE PLASTIC SURGERY"
          }
        }
      ]
    }
  ]
}
{% endschema %}
