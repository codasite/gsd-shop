<section class="collection-grid" data-section-id="{{ section.id }}">
  <div class="section-wrapper">
    <h1 class="page-heading">{{ collection.title }}</h1>

    {% if collection.products.size > 0 %}
      <p class="results-count">
        Showing {{ collection.products.size }} results
      </p>

      <div class="collection-toolbar">
        <div class="collection-sort">
          <select id="SortBy" class="sort-select">
            <option value="manual">Default sorting</option>
            <option value="best-selling">Sort by popularity</option>
            <option value="title-ascending">Sort by name: A-Z</option>
            <option value="title-descending">Sort by name: Z-A</option>
            <option value="created-descending">Sort by latest</option>
          </select>
        </div>
      </div>
    {% endif %}

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="product-grid product-grid--4col">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="pagination">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 16
    }
  ]
}
{% endschema %}
