<header class="site-header" data-section-id="{{ section.id }}">
  <div class="header-wrapper">
    <a href="/" class="site-logo">
      {% if section.settings.logo %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
      {% else %}
        <div class="logo-placeholder">
          <div class="logo-circle">
            <span class="logo-initials">GSD</span>
          </div>
          <div class="logo-text">
            <span class="logo-line-1">GOLDEN STATE</span>
            <span class="logo-line-2">DERMATOLOGY</span>
            <span class="logo-line-3">SHOP</span>
          </div>
        </div>
      {% endif %}
    </a>

    <nav class="main-nav" role="navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
  <div class="header-accent-line"></div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
