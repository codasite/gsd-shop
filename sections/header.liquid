<header class="site-header" data-section-id="{{ section.id }}">
  <div class="header-wrapper">
    <a href="/" class="site-logo">
      {% if section.settings.logo %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
      {% else %}
        <img src="{{ 'gsd-shop-logo.png' | asset_url }}" alt="{{ shop.name }}" class="logo-img">
      {% endif %}
    </a>

    <nav class="main-nav" role="navigation">
      {% if section.settings.menu.links.size > 0 %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">
            {{ link.title }}
          </a>
        {% endfor %}
      {% else %}
        <a href="/account" class="nav-link">My account</a>
        <a href="/collections" class="nav-link">Shop by Brand</a>
        <a href="/cart" class="nav-link">Cart</a>
        <a href="/checkout" class="nav-link">Checkout</a>
      {% endif %}
    </nav>

    <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
