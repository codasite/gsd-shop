<header class="site-header" data-section-id="{{ section.id }}">
  <div class="header-wrapper">
    <a href="/" class="site-logo">
      {% if section.settings.logo %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
      {% else %}
        <span class="site-title">{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="main-nav" role="navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <div class="header-actions">
      <a href="/search" class="header-icon" aria-label="Search">
        {% render 'icon-search' %}
      </a>
      <a href="/account" class="header-icon" aria-label="Account">
        {% render 'icon-account' %}
      </a>
      <a href="/cart" class="header-icon cart-link" aria-label="Cart">
        {% render 'icon-cart' %}
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
