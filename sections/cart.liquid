<section class="cart-section" data-section-id="{{ section.id }}">
  <div class="section-wrapper">
    <h1>Your Cart</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item" data-variant-id="{{ item.variant.id }}">
              <div class="cart-item-image">
                {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
              </div>

              <div class="cart-item-details">
                <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="cart-item-variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="cart-item-price">{{ item.price | money }}</p>
              </div>

              <div class="cart-item-quantity">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"
                  data-line="{{ forloop.index }}">
              </div>

              <div class="cart-item-total">
                {{ item.line_price | money }}
              </div>

              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item-remove">
                Remove
              </a>
            </div>
          {% endfor %}
        </div>

        <div class="cart-footer">
          <div class="cart-total">
            <span>Subtotal:</span>
            <span class="cart-total-price">{{ cart.total_price | money }}</span>
          </div>

          <p class="cart-note">Shipping and taxes calculated at checkout.</p>

          <button type="submit" name="checkout" class="btn btn-primary">
            Checkout
          </button>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <p>Your cart is empty.</p>
        <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
